{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-var": "off",
    "prefer-const": "off",
    "eqeqeq": "error",
    "no-unused-vars": ["warn", { "args": "none" }]
  }
}
